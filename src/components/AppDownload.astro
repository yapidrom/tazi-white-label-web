---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="download" class="py-20 sm:py-28 bg-gradient-to-br from-primary-600 via-primary-700 to-primary-800 relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>
  </div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
      <!-- Text Content -->
      <div class="flex-1 text-center lg:text-left" data-animate>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight">
          {t('app.title')}
        </h2>
        <p class="mt-4 text-lg text-primary-100/80 max-w-lg">
          {t('app.subtitle')}
        </p>

        <!-- Store Badges -->
        <div class="flex flex-col sm:flex-row gap-4 mt-8 justify-center lg:justify-start">
          <!-- App Store -->
          <a
            href="#"
            class="inline-flex items-center gap-3 bg-black hover:bg-gray-900 text-white px-6 py-3.5 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
          >
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
            </svg>
            <div class="text-left">
              <div class="text-xs opacity-80">{lang === 'tr' ? "İndir" : "Download on the"}</div>
              <div class="text-lg font-semibold leading-tight">App Store</div>
            </div>
          </a>

          <!-- Google Play -->
          <a
            href="#"
            class="inline-flex items-center gap-3 bg-black hover:bg-gray-900 text-white px-6 py-3.5 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg"
          >
            <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.24-.84-.76-.84-1.35m13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27m3.35-4.31c.34.27.56.69.56 1.19s-.22.92-.56 1.19l-2.29 1.32-2.5-2.5 2.5-2.5 2.29 1.3M6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z" />
            </svg>
            <div class="text-left">
              <div class="text-xs opacity-80">{lang === 'tr' ? "İndir" : "Get it on"}</div>
              <div class="text-lg font-semibold leading-tight">Google Play</div>
            </div>
          </a>
        </div>
      </div>

      <!-- Phone Mockup -->
      <div class="flex-shrink-0" data-animate="fade-right">
        <div class="relative w-64 h-[500px] bg-slate-900 rounded-[3rem] p-3 shadow-2xl border-4 border-slate-700">
          <!-- Screen -->
          <div class="w-full h-full rounded-[2.25rem] bg-gradient-to-br from-primary-400 to-emerald-500 overflow-hidden flex flex-col items-center justify-center text-white">
            <!-- Notch -->
            <div class="absolute top-3 left-1/2 -translate-x-1/2 w-24 h-6 bg-slate-900 rounded-full"></div>

            <!-- App mockup content -->
            <div class="text-center px-6">
              <div class="w-16 h-16 bg-white/20 rounded-2xl mx-auto mb-4 flex items-center justify-center">
                <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold">Merbis</h3>
              <p class="text-sm text-white/70 mt-2">
                {lang === 'tr' ? 'Mikromobilite\nUygulaması' : 'Micromobility\nApp'}
              </p>
            </div>

            <!-- Fake map preview -->
            <div class="absolute bottom-12 left-3 right-3 h-32 bg-white/10 backdrop-blur-sm rounded-2xl p-3">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                <span class="text-xs font-medium">
                  {lang === 'tr' ? '3 araç yakınında' : '3 vehicles nearby'}
                </span>
              </div>
              <div class="space-y-1.5">
                <div class="h-2 bg-white/20 rounded-full w-full"></div>
                <div class="h-2 bg-white/20 rounded-full w-3/4"></div>
                <div class="h-2 bg-white/20 rounded-full w-1/2"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
