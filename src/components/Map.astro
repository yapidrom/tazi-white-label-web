---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import MapIsland from './MapIsland';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || '';
---

<section id="map" class="py-20 sm:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t('map.title')}</h2>
      <p class="mt-4 text-lg text-slate-600">{t('map.subtitle')}</p>
    </div>

    <!-- Map Container -->
    <div class="mt-12 rounded-2xl overflow-hidden shadow-xl border border-slate-200 h-[400px] sm:h-[500px]" data-animate>
      <MapIsland client:visible lang={lang} apiKey={googleMapsApiKey} />
    </div>
  </div>
</section>
