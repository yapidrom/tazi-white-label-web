---
import type { Lang } from '../i18n/utils';
import { useTranslations, getLocalePath } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const navLinks = [
  { href: '#how-it-works', label: t('nav.howItWorks') },
  { href: '#gallery', label: t('nav.gallery') },
  { href: '#pricing', label: t('nav.pricing') },
  { href: '#map', label: t('nav.map') },
  { href: '#faq', label: t('nav.faq') },
  { href: '#contact', label: t('nav.contact') },
];

const legalLinks = [
  { id: 'open-delete-modal', label: t('legal.deleteAccount') },
  { id: 'open-terms-modal', label: t('legal.terms') },
  { id: 'open-privacy-modal', label: t('legal.privacy') },
  { id: 'open-kvkk-modal', label: t('legal.kvkk') },
  { id: 'open-camera-modal', label: t('legal.camera') },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-50 bg-[#373632] backdrop-blur-lg border-b border-[#373632] transition-all duration-300"
  id="navbar"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo (instant jump to top, no smooth scroll) -->
      <a href={getLocalePath(lang)} id="logo-link" class="flex items-center group">
        <img src="/logo.png" alt="Merbis" class="h-44 w-auto group-hover:scale-105 transition-transform duration-200" />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="px-3 py-2 text-sm font-medium text-white hover:text-primary-500 rounded-lg hover:bg-white/10 transition-all duration-200"
          >
            {link.label}
          </a>
        ))}

        <!-- Yasal Dropdown -->
        <div class="relative" id="legal-dropdown">
          <button
            class="px-3 py-2 text-sm font-medium text-white hover:text-primary-500 rounded-lg hover:bg-white/10 transition-all duration-200 inline-flex items-center gap-1"
            id="legal-dropdown-btn"
          >
            {t('nav.legal')}
            <svg class="w-3.5 h-3.5 transition-transform duration-200" id="legal-dropdown-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id="legal-dropdown-menu"
            class="absolute right-0 top-full mt-1 w-52 bg-[#373632] rounded-xl shadow-lg border border-white/10 py-1.5 opacity-0 scale-95 pointer-events-none transition-all duration-200 origin-top-right"
          >
            {legalLinks.map((link) => (
              <button
                id={link.id}
                class="legal-modal-trigger w-full text-left px-4 py-2.5 text-sm text-white hover:text-primary-500 hover:bg-white/10 transition-colors"
              >
                {link.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Right side: CTA + Mobile menu -->
      <div class="flex items-center gap-3">
        <!-- CTA Button (desktop) -->
        <a
          href="#download"
          class="hidden sm:inline-flex items-center gap-2 bg-primary-500 hover:bg-primary-600 text-primary-950 text-sm font-semibold px-4 py-2 rounded-lg transition-all shadow-sm hover:shadow-md hover:-translate-y-0.5 active:translate-y-0 duration-200"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          {t('nav.download')}
        </a>

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-slate-300 hover:bg-white/10 transition-colors active:scale-90 transition-transform duration-150"
          aria-label="Menu"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-white/10 bg-[#373632] backdrop-blur-lg max-h-[calc(100vh-4rem)] overflow-y-auto"
  >
    <div class="px-4 py-4 space-y-1 pb-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link block px-3 py-2.5 text-base font-medium text-white hover:text-primary-500 hover:bg-white/10 rounded-lg transition-colors"
        >
          {link.label}
        </a>
      ))}

      <!-- Mobile Legal Submenu -->
      <div class="border-t border-white/10 pt-2 mt-2">
        <p class="px-3 py-1.5 text-xs font-semibold text-slate-500 uppercase tracking-wider">{t('nav.legal')}</p>
        {legalLinks.map((link) => (
          <button
            id={`mobile-${link.id}`}
            class="legal-modal-trigger mobile-nav-link w-full text-left block px-3 py-2.5 text-base font-medium text-white hover:text-primary-500 hover:bg-white/10 rounded-lg transition-colors"
          >
            {link.label}
          </button>
        ))}
      </div>

      <a
        href="#download"
        class="mobile-nav-link block mt-3 text-center bg-primary-500 hover:bg-primary-600 text-primary-950 font-semibold px-4 py-3 rounded-lg transition-colors"
      >
        {t('nav.download')}
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = menu?.querySelectorAll('.mobile-nav-link');

  function openMenu() {
    menu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', () => {
    if (menu?.classList.contains('hidden')) {
      openMenu();
    } else {
      closeMenu();
    }
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });

  // Logo: instant teleport to top
  const logoLink = document.getElementById('logo-link');
  logoLink?.addEventListener('click', (e) => {
    e.preventDefault();
    document.documentElement.style.scrollBehavior = 'auto';
    window.scrollTo(0, 0);
    requestAnimationFrame(() => {
      document.documentElement.style.scrollBehavior = '';
    });
  });

  // Desktop Legal Dropdown
  const dropdownBtn = document.getElementById('legal-dropdown-btn');
  const dropdownMenu = document.getElementById('legal-dropdown-menu');
  const dropdownArrow = document.getElementById('legal-dropdown-arrow');
  let dropdownOpen = false;

  function toggleDropdown(open: boolean) {
    dropdownOpen = open;
    if (open) {
      dropdownMenu?.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
      dropdownMenu?.classList.add('opacity-100', 'scale-100');
      dropdownArrow?.classList.add('rotate-180');
    } else {
      dropdownMenu?.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
      dropdownMenu?.classList.remove('opacity-100', 'scale-100');
      dropdownArrow?.classList.remove('rotate-180');
    }
  }

  dropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleDropdown(!dropdownOpen);
  });

  document.addEventListener('click', (e) => {
    const dropdown = document.getElementById('legal-dropdown');
    if (dropdownOpen && dropdown && !dropdown.contains(e.target as Node)) {
      toggleDropdown(false);
    }
  });
</script>
