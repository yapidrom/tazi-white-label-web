---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const plans = [
  {
    name: t('pricing.scooter'),
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    unlock: '₺3',
    perMin: '₺2.50',
    popular: false,
  },
  {
    name: t('pricing.daily'),
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>`,
    price: '₺49',
    desc: t('pricing.dailyDesc'),
    popular: true,
  },
  {
    name: t('pricing.monthly'),
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>`,
    price: '₺199',
    desc: t('pricing.monthlyDesc'),
    popular: false,
  },
];
---

<section id="pricing" class="py-20 sm:py-28 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto" data-animate>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">{t('pricing.title')}</h2>
      <p class="mt-4 text-lg text-slate-600">{t('pricing.subtitle')}</p>
    </div>

    <!-- Pricing Cards -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto" data-stagger>
      {plans.map((plan) => (
        <div
          class:list={[
            'card-hover relative bg-white rounded-2xl p-8 border-2 transition-colors',
            plan.popular ? 'border-primary-500 shadow-lg shadow-primary-100' : 'border-slate-200',
          ]}
        >
          {plan.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary-600 text-white text-sm font-semibold px-4 py-1 rounded-full">
              {t('pricing.popular')}
            </div>
          )}

          {/* Icon */}
          <div
            class:list={[
              'inline-flex items-center justify-center w-14 h-14 rounded-xl mb-5',
              plan.popular ? 'bg-primary-100 text-primary-600' : 'bg-slate-100 text-slate-600',
            ]}
          >
            <Fragment set:html={plan.icon} />
          </div>

          {/* Name */}
          <h3 class="text-xl font-bold text-slate-900">{plan.name}</h3>

          {/* Pricing */}
          {'price' in plan ? (
            <div class="mt-4">
              <span class="text-4xl font-extrabold text-slate-900">{plan.price}</span>
              <p class="mt-2 text-sm text-slate-600">{plan.desc}</p>
            </div>
          ) : (
            <div class="mt-4 space-y-2">
              <div class="flex justify-between items-center">
                <span class="text-sm text-slate-600">{t('pricing.unlock')}</span>
                <span class="font-bold text-slate-900">{plan.unlock}</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-sm text-slate-600">{t('pricing.perMin')}</span>
                <span class="font-bold text-slate-900">{plan.perMin}</span>
              </div>
            </div>
          )}

          {/* CTA */}
          <a
            href="#download"
            class:list={[
              'mt-8 block text-center font-semibold py-3 rounded-xl transition-colors',
              plan.popular
                ? 'bg-primary-600 hover:bg-primary-700 text-white'
                : 'bg-slate-100 hover:bg-slate-200 text-slate-900',
            ]}
          >
            {t('hero.cta')}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
